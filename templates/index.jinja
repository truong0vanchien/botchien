{% extends "base.jinja" %}

{% block body %}
<div class="container-fluid px-4 mt-4">
<div class="d-flex justify-content-between align-items-center mb-4">
<div style="width: 150px;">
<a href="https://github.com/truong0vanchien/botchien" target="_blank" class="btn btn-outline-dark btn-sm fw-semibold shadow-sm d-inline-flex align-items-center gap-1">
  <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" fill="currentColor" class="bi bi-github" viewBox="0 0 16 16">
    <path d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27s1.36.09 2 .27c1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.01 8.01 0 0 0 16 8c0-4.42-3.58-8-8-8"/>
  </svg>
  GitHub
</a>
</div>
<h2 class="mb-0 text-center flex-grow-1 fw-bold" data-i18n="Ask me anything about Truong Van Chien">Ask me anything about Truong Van Chien</h2>
<div style="width: 150px;" class="text-end">
<select id="langSelect" class="form-select form-select-lg d-inline-block fw-bold border-primary shadow-sm" style="width: auto; min-width: 90px; cursor: pointer;">
<option value="vi">VI</option>
<option value="en">EN</option>
</select>
</div>
</div>

<!-- SUBJECT (Hidden) -->
<select id="subjectInput" style="display: none;">
<option value="asky" selected>asky</option>
</select>

<!-- TWO COLUMNS -->
<div class="row">
  <!-- LEFT COLUMN: DEFINITION & TRAINING (1/3) -->
  <div class="col-md-4 mb-4">
    <!-- DEFINITION -->
    <div class="card p-4 mb-4 shadow-sm d-flex flex-column" style="min-height: 250px;">
      <label for="definitionInput" class="form-label text-label fw-bold" data-i18n="DEFINITION">DEFINITION</label>
      <textarea class="form-control mb-2 flex-grow-1" id="definitionInput" rows="5" placeholder="Definition will be loaded from Supabase..." data-i18n-placeholder="Definition will be loaded from Supabase..." disabled></textarea>
      <div class="text-end mt-auto">
        <button type="button" class="btn btn-warning btn-sm" id="btnEditDef" data-i18n="UPDATE">UPDATE</button>
        <div id="groupDefActions" class="d-none d-inline-block">
          <button type="button" class="btn btn-secondary btn-sm me-1" id="btnCancelDef" data-i18n="CANCEL">CANCEL</button>
          <button type="button" class="btn btn-warning btn-sm" id="btnOverwriteDef" data-i18n="SAVE">SAVE</button>
        </div>
      </div>
    </div>
    
    <!-- TRAINING -->
    <div class="card p-4 shadow-sm d-flex flex-column" style="min-height: 400px;">
      <label for="trainingInput" class="form-label text-label fw-bold" data-i18n="TRAINING">TRAINING</label>
      <textarea class="form-control mb-2 flex-grow-1" id="trainingInput" rows="12" placeholder="Training data will be loaded from Supabase..." data-i18n-placeholder="Training data will be loaded from Supabase..." disabled></textarea>
      <div class="text-end mt-auto">
        <button type="button" class="btn btn-warning btn-sm" id="btnEditTrain" data-i18n="UPDATE">UPDATE</button>
        <div id="groupTrainActions" class="d-none d-inline-block">
          <button type="button" class="btn btn-secondary btn-sm me-1" id="btnCancelTrain" data-i18n="CANCEL">CANCEL</button>
          <button type="button" class="btn btn-warning btn-sm" id="btnOverwriteTrain" data-i18n="SAVE">SAVE</button>
        </div>
      </div>
    </div>
  </div>

  <!-- RIGHT COLUMN: QUESTION & ANSWER (2/3) -->
  <div class="col-md-8 mb-4">
    <!-- QUESTION -->
    <div class="card p-4 mb-4 shadow-sm d-flex flex-column" style="min-height: 250px;">
      <label for="contentInput" class="form-label text-label fw-bold" data-i18n="QUESTION">QUESTION</label>
      <textarea class="form-control flex-grow-1" id="contentInput" rows="5" placeholder="E.g., What is his current role? / What is his core tech stack? / Tell me about his Conveyor Belt 3D Printer project. / What certificates does he have?" data-i18n-placeholder="E.g., What is his current role? / What is his core tech stack? / Tell me about his Conveyor Belt 3D Printer project. / What certificates does he have?"></textarea>
    </div>

    <!-- ANSWER & SUBMIT -->
    <div class="card p-4 shadow-sm d-flex flex-column" style="min-height: 400px;">
      <label for="answerOutput" class="form-label text-label fw-bold" data-i18n="ANSWER">ANSWER</label>
      <div id="answerOutput" class="form-control flex-grow-1 mb-3" style="min-height: 220px; background-color: #f8f9fa; overflow-y: auto; padding: 15px;"></div>
      <div class="text-center mt-auto">
        <button type="submit" class="btn btn-primary submit-button btn-lg w-100" data-i18n="SUBMIT">SUBMIT</button>
      </div>
    </div>
  </div>
</div>
</div>

{% include 'frmLoading.jinja' %}
{% endblock body %}
